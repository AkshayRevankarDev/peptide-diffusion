% neurips_2023.sty  — Minimal NeurIPS 2023 style for checkpoint submissions
% Replicates key layout from the official NeurIPS 2023 template.
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{neurips_2023}[2023/06/01 NeurIPS 2023 Style]

\usepackage[T1]{fontenc}
\usepackage{times}
\usepackage{microtype}
\usepackage{helvet}
\usepackage{courier}

% Page geometry — NeurIPS standard
\usepackage[
  letterpaper,
  top=1in,
  bottom=1.5in,
  left=1.5in,
  right=1.5in
]{geometry}

\usepackage{amsmath,amsfonts,amssymb}
\usepackage{booktabs}
\usepackage{graphicx}
\usepackage{xcolor}
\usepackage{hyperref}
\usepackage{url}
\usepackage{natbib}
\usepackage{caption}
\usepackage{subcaption}
\usepackage{enumitem}
\usepackage{array}
\usepackage{multirow}

\hypersetup{
  colorlinks=true,
  linkcolor=black,
  citecolor=black,
  urlcolor=[rgb]{0,0.4,0.8}
}

% Font size
\renewcommand{\normalsize}{\fontsize{10}{12}\selectfont}
\normalsize

% Title
\newcommand{\@neurips@title}{}
\renewcommand{\title}[1]{\renewcommand{\@neurips@title}{#1}}

% Author block
\newcommand{\@neurips@author}{}
\renewcommand{\author}[1]{\renewcommand{\@neurips@author}{#1}}

% Maketitle
\renewcommand{\maketitle}{%
  \begin{center}
    {\LARGE\bfseries \@neurips@title \par}
    \vskip 0.5em
    {\large \@neurips@author \par}
  \end{center}
  \vskip 1em
  \hrule
  \vskip 1em
}

% Abstract
\renewenvironment{abstract}{%
  \begin{center}
    \bfseries Abstract
  \end{center}
  \begin{quote}\small
}{%
  \end{quote}
  \vskip 1em
}

% Section formatting
\usepackage{titlesec}
\titleformat{\section}{\large\bfseries}{\thesection}{1em}{}
\titleformat{\subsection}{\normalsize\bfseries}{\thesubsection}{1em}{}
\titleformat{\subsubsection}{\normalsize\itshape}{\thesubsubsection}{1em}{}

\titlespacing*{\section}{0pt}{1.5ex plus 1ex minus .2ex}{0.5ex plus .2ex}
\titlespacing*{\subsection}{0pt}{1ex plus 1ex minus .2ex}{0.3ex plus .2ex}

% Paragraph
\setlength{\parskip}{4pt}
\setlength{\parindent}{0pt}

% Caption styling
\captionsetup{font=small,labelfont=bf,skip=4pt}

% Footer note
\usepackage{fancyhdr}
\pagestyle{fancy}
\fancyhf{}
\renewcommand{\headrulewidth}{0pt}
\fancyfoot[C]{\small\thepage}
